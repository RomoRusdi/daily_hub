# Salin file ini menjadi ".env" lalu isi nilai dari project Supabase-mu.
# Lokasi: Supabase Dashboard -> Project Settings -> API
# (Anon key aman dipakai di frontend KARENA RLS per-user aktif — lihat SUPABASE.md.)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Kunci PUBLIK VAPID untuk Web Push (aman di frontend). Generate sepasang:
#   npx web-push generate-vapid-keys
# Kunci PRIVATE-nya JANGAN di sini — set sebagai secret Edge Function.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
